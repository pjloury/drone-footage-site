<?xml version="1.0" encoding="utf-8"?>
<!-- TV banner: 320×180 dp, shown in the Android TV launcher grid.
     Replace this with a designed PNG at res/drawable-xhdpi/tv_banner.png
     (640×360 px) before submitting to the Play Store. -->
